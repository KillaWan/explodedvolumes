{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build OpenGL",
        "type": "shell",
        "command": "/usr/bin/clang++",
        "args": [
            "-std=c++17",
            "-fdiagnostics-color=always",
            "-Wall",
            "-g",
            "-arch", "arm64",
            "${workspaceFolder}/main.cpp",
            "${workspaceFolder}/glad.c",
            "-I${workspaceFolder}/dependencies/include", 
            "-L${workspaceFolder}/dependencies/library",      // 添加包含路径
            "-o", "${workspaceFolder}/app",
            "-L/opt/homebrew/lib",           // 链接库路径
            "-lglfw",                       // 链接 GLFW 库
            "-framework", "OpenGL",
            "-framework", "Cocoa",
            "-DGL_SILENCE_DEPRECATION"
        ],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": "$gcc"
      }
    ]
  }
  